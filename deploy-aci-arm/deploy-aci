    return region.replace(" ", "").strip().lower()


def effective_deployment_resource_group(args: argparse.Namespace) -> str:
    if not args.deploy_rg:
        return args.resource_group
    return f"{args.resource_group}-{args.name}"


def build_deployment_context(args: argparse.Namespace) -> DeploymentContext:
    return DeploymentContext(
        base_resource_group=args.resource_group,
        deployment_resource_group=effective_deployment_resource_group(args),
        region=args.region,
    )


