def prepare_azure_file_mount_configs(
    plan: AzureFilePlan | None,
    context: DeploymentContext,
) -> list[AzureFileMountConfig | None]:
    if plan is None:
        return []

    storage_account_name = plan.mounts[0].storage_account_name
    if plan.storage_mode == AzureFileStorageMode.MANAGED:
        create_storage_account(
            context.deployment_resource_group,
            storage_account_name,
            context.region,
        )
    else:
        checked_accounts = {
            mount.storage_account_name for mount in plan.mounts
        }
        for existing_account_name in checked_accounts:
            storage_region = get_storage_account_region(
                context.deployment_resource_group,
                existing_account_name,
            )
            if normalize_region_name(storage_region) != normalize_region_name(context.region):
                raise ValueError(
                    "existing Azure Files storage account must be in the deployment region"
                )

    created_shares: set[tuple[str, str]] = set()
    for mount in plan.mounts:
        share_id = (mount.storage_account_name, mount.share_name)
        if share_id in created_shares:
            continue
        created_shares.add(share_id)
        create_azure_file_share(
            context.deployment_resource_group,
            mount.storage_account_name,
            mount.share_name,
        )

    storage_key = (
        get_storage_account_key(context.deployment_resource_group, storage_account_name)
        if plan.storage_mode == AzureFileStorageMode.MANAGED
        else None
    )

    mount_configs = []
    for mount in plan.mounts:
        if plan.storage_mode == AzureFileStorageMode.EXISTING:
            if mount.key_file is not None:
                resolved_storage_key = get_secret_file_contents(mount.key_file)
            else:
                resolved_storage_key = get_storage_account_key(
                    context.deployment_resource_group,
                    mount.storage_account_name,
                )
        else:
            resolved_storage_key = storage_key

        mount_configs.append(
            AzureFileMountConfig(
                storage_account_name=mount.storage_account_name,
                share_name=mount.share_name,
                mount_path=mount.mount_path,
                storage_account_key_parameter=azure_file_storage_key_parameter_name(
                    mount.node_index
                ),
                storage_account_key=resolved_storage_key,
                volume_name=f"azurefiles{mount.node_index + 1}",
            )
        )

    return mount_configs


