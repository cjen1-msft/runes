{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {},
  "resources": [
    {
      "apiVersion": "2023-09-01",
      "location": "northeurope",
      "name": "existing-vnet",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            ""
          ]
        },
        "subnets": [
          {
            "name": "existing-subnet",
            "properties": {
              "addressPrefix": "",
              "defaultoutboundaccess": false
            }
          }
        ]
      },
      "type": "Microsoft.Network/virtualNetworks"
    },
    {
      "apiVersion": "2022-10-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', 'existing-vnet')]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "location": "northeurope",
      "name": "baseline-existing-1",
      "properties": {
        "confidentialComputeProperties": {
          "ccePolicy": ""
        },
        "containers": [
          {
            "name": "baseline-existing-0",
            "properties": {
              "command": [
                "/bin/sh",
                "-c",
                "echo Fabric_NodeIPOrFQDN=$Fabric_NodeIPOrFQDN >> /aci_env && echo UVM_SECURITY_CONTEXT_DIR=$UVM_SECURITY_CONTEXT_DIR >> /aci_env && mkdir -p /root/.ssh/ && gpg --import /etc/pki/rpm-gpg/MICROSOFT-RPM-GPG-KEY && tdnf update -y && tdnf install -y openssh-server ca-certificates && tail -f /dev/null"
              ],
              "environmentVariables": [],
              "image": "ghcr.io/example/image:latest",
              "ports": [
                {
                  "port": 22,
                  "protocol": "TCP"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 4,
                  "memoryInGB": 16
                }
              },
              "securityContext": {
                "privileged": true
              },
              "volumeMounts": []
            }
          }
        ],
        "ipAddress": {
          "ports": [
            {
              "port": "22",
              "protocol": "TCP"
            }
          ],
          "type": "Private"
        },
        "osType": "Linux",
        "restartPolicy": "Never",
        "sku": "Confidential",
        "subnetIds": [
          {
            "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'existing-vnet', 'existing-subnet')]"
          }
        ],
        "volumes": []
      },
      "type": "Microsoft.ContainerInstance/containerGroups"
    }
  ],
  "variables": {}
}
