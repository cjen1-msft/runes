    delete_command: list[str] | None = None,
) -> None:
    print("Deployed")
    for cidx in range(num_containers):
        container_group_name = f"{deployment_name}-{cidx + 1}"

        if access_mode == "exec":
            print(f"Connect to container {cidx + 1} using:")
            print(
                f"az container exec --resource-group {resource_group} --name {container_group_name} --exec-command /bin/bash"
            )
            print("")
            continue

        requested_ip = requested_private_ip_for_index(cidx)
        lb_name = load_balancer_name(container_group_name)
        try:
            actual_ip = get_container_group_private_ip(resource_group, container_group_name)
        except CalledProcessError:
            actual_ip = None
            print(
                f"Warning: unable to determine actual private IP for {container_group_name}. Skipping load balancer backend update."
            )

        if actual_ip == "":
            actual_ip = None
            print(
                f"Warning: {container_group_name} did not report a private IP. Skipping load balancer backend update."
            )

        backend_name = load_balancer_backend_address_name(lb_name)

        if actual_ip is not None:
            if actual_ip != requested_ip:
                print(
                    f"Warning: {container_group_name} requested private IP {requested_ip} but Azure assigned {actual_ip}. Registering actual IP in load balancer backend address."
                )

            add_load_balancer_backend_address(
                resource_group,
                lb_name,
                backend_name,
                actual_ip,
                vnet_name,
                subnet_name,
            )
        else:
            print(
                f"Warning: backend address registration skipped for {container_group_name} because no private IP was available."
            )

        print(f"Connect to container {cidx + 1} using:")
        public_ip_name = load_balancer_public_ip_name(container_group_name)
        ssh_command = f"ssh -i {ssh_key_path} root@<public-ip> -p 22"
        try:
            public_ip = get_public_ip_address(resource_group, public_ip_name)
            print(f"ssh -i {ssh_key_path} root@{public_ip} -p 22")
        except CalledProcessError:
            print(
                f"Resolve public IP resource {public_ip_name} manually, then run: {ssh_command}"
            )
        print("")

    if delete_command is not None:
        print("Cleanup command:")
        print(shlex.join(delete_command))


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    validate_args(parser, args)

    resources, context = build_generated_resources(args)

    if args.delete:
        failures = execute_delete_plan(args.resource_group, build_delete_plan(resources))
        sys.exit(1 if failures else 0)

    print_resource_topology_message(args, context)

    azure_file_mount_config = build_azure_file_mount_config(args)
    deployment = tb.ARMTemplate(
        resources,
        parameters=arm_parameters_for_mount(azure_file_mount_config),
    )

    with tempfile.NamedTemporaryFile() as tempf, tempfile.NamedTemporaryFile() as paramsf:
        dep_json = deployment.to_json()
        if args.dry_run is True:
            print(dep_json)
            exit(0)
        tempf.write(dep_json.encode("utf-8"))
        tempf.flush()
        parameter_values = arm_parameter_values_for_mount(azure_file_mount_config)
        if parameter_values:
            write_parameters_file(paramsf, parameter_values)

        az_cmd = [
            "az",
            "deployment",
            "group",
            "create",
            "--resource-group",
            args.resource_group,
            "--template-file",
            tempf.name,
        ] + (
            ["--parameters", f"@{paramsf.name}"] if parameter_values else []
        ) + (["--verbose", "--debug"] if args.verbose else [])
        print("Running:")
        print(shlex.join(az_cmd))
        run(az_cmd, check=True)

    delete_command = render_delete_command(args)

    if args.create_vnet is True or args.vnet_subnet is not None:
        print_post_deploy_access(
            resource_group=args.resource_group,
            deployment_name=args.name,
            num_containers=args.num_containers,
            access_mode=args.access_mode,
            ssh_key_path=args.ssh_key,
            vnet_name=context["vnet_name"],
            subnet_name=context["subnet_name"],
            delete_command=delete_command,
        )
    else:
        for cidx in range(args.num_containers):
            run(
                [
                    "az",
                    "container",
                    "show",
                    "--resource-group",
                    args.resource_group,
                    "--name",
                    f"{args.name}-{cidx + 1}",
                    "--query",
                    "ipAddress.ip",
                ]
            )
        print("Cleanup command:")
        print(shlex.join(delete_command))


if __name__ == "__main__":
    main()
