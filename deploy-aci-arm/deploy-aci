def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    validate_args(parser, args)

    context = build_deployment_context(args)
    try:
        azure_file_plan = build_azure_file_plan(args, context)
    except ValueError as exc:
        parser.error(str(exc))

    mount_configs_for_resources = (
        [
            AzureFileMountConfig(
                storage_account_name=mount.storage_account_name,
                share_name=mount.share_name,
                mount_path=mount.mount_path,
                storage_account_key_parameter=azure_file_storage_key_parameter_name(
                    mount.node_index
                ),
                volume_name=f"azurefiles{mount.node_index + 1}",
            )
            for mount in azure_file_plan.mounts
        ]
        if azure_file_plan is not None
        else [None for _ in range(args.num_containers)]
    )

    resources, resource_context = build_generated_resources(args, mount_configs_for_resources)

    if args.delete:
        failures = execute_delete_plan(
            context.deployment_resource_group,
            build_delete_plan(resources),
        )
        if azure_file_plan is not None:
            failures.extend(
                execute_share_delete_plan(
                    context.deployment_resource_group,
                    azure_file_plan.mounts,
                )
            )
        sys.exit(1 if failures else 0)

    print_resource_topology_message(args, resource_context)

    deployment = tb.ARMTemplate(
        resources,
        parameters=arm_parameters_for_mounts(mount_configs_for_resources),
    )

    with tempfile.NamedTemporaryFile() as tempf, tempfile.NamedTemporaryFile() as paramsf:
        dep_json = deployment.to_json()
        if args.dry_run is True:
            print(dep_json)
            print_dry_run_actions(context, azure_file_plan)
            exit(0)
        tempf.write(dep_json.encode("utf-8"))
        tempf.flush()
        ensure_resource_group(context)
        realized_mount_configs = prepare_azure_file_mount_configs(azure_file_plan, context)
        parameter_values = arm_parameter_values_for_mounts(realized_mount_configs)
        if parameter_values:
            write_parameters_file(paramsf, parameter_values)

        az_cmd = [
            "az",
            "deployment",
            "group",
            "create",
            "--resource-group",
            context.deployment_resource_group,
            "--template-file",
            tempf.name,
        ] + (
            ["--parameters", f"@{paramsf.name}"] if parameter_values else []
        ) + (["--verbose", "--debug"] if args.verbose else [])
        print("Running:")
        print(shlex.join(az_cmd))
        run(az_cmd, check=True)

    delete_command = render_delete_command(args)

    if args.create_vnet is True or args.vnet_subnet is not None:
        print_post_deploy_access(
            resource_group=context.deployment_resource_group,
            deployment_name=args.name,
            num_containers=args.num_containers,
            access_mode=args.access_mode,
            ssh_key_path=args.ssh_key,
            vnet_name=resource_context["vnet_name"],
            subnet_name=resource_context["subnet_name"],
            delete_command=delete_command,
        )
    else:
        for cidx in range(args.num_containers):
            run(
                [
                    "az",
                    "container",
                    "show",
                    "--resource-group",
                    context.deployment_resource_group,
                    "--name",
                    f"{args.name}-{cidx + 1}",
                    "--query",
                    "ipAddress.ip",
                ]
            )
        print("Cleanup command:")
        print(shlex.join(delete_command))


if __name__ == "__main__":
    main()
