def parse_azure_file_mount_spec(spec: str) -> ParsedAzureFileMount:
    values: dict[str, str] = {}
    for entry in spec.split(","):
        entry = entry.strip()
        if entry == "":
            continue
        key, separator, value = entry.partition("=")
        if separator == "":
            raise ValueError(
                "must use key=value pairs separated by commas"
            )
        normalized_key = key.strip()
        if normalized_key not in {"account", "share", "path", "key-file"}:
            raise ValueError(f"contains unsupported key '{normalized_key}'")
        if normalized_key in values:
            raise ValueError(f"contains duplicate key '{normalized_key}'")
        values[normalized_key] = value.strip()

    share_name = values.get("share", "").strip()
    mount_path = values.get("path", "").strip()
    storage_account_name = values.get("account")
    if storage_account_name is not None:
        storage_account_name = storage_account_name.strip() or None
    key_file = values.get("key-file")
    if key_file is not None:
        key_file = key_file.strip() or None

    return ParsedAzureFileMount(
        storage_account_name=storage_account_name,
        share_name=share_name,
        mount_path=mount_path,
        key_file=key_file,
    )


def validate_parsed_azure_file_mount(
    parser: argparse.ArgumentParser,
    mount: ParsedAzureFileMount,
    mount_index: int,
) -> None:
    mount_label = f"--azure-file-mount #{mount_index + 1}"
    if mount.share_name == "":
        parser.error(f"{mount_label} requires share=<name>")
    if mount.mount_path == "":
        parser.error(f"{mount_label} requires path=<absolute-path>")
    if not mount.mount_path.startswith("/"):
        parser.error(f"{mount_label} path must be an absolute path")
    if mount.storage_account_name is None and mount.key_file is not None:
        parser.error(
            f"{mount_label} cannot use key-file=... when account=... is omitted"
        )
    if mount.key_file is not None:
        key_file_path = os.path.expanduser(mount.key_file)
        if not os.path.isfile(key_file_path):
            parser.error(f"{mount_label} key-file must point to an existing file")
        if not os.access(key_file_path, os.R_OK):
            parser.error(f"{mount_label} key-file must be readable")
        if get_secret_file_contents(mount.key_file) == "":
            parser.error(f"{mount_label} key-file cannot be empty")


def derived_share_name(share_prefix: str, node_index: int) -> str:
    return f"{share_prefix.rstrip('-')}-{node_index + 1}"


def derived_storage_account_name(context: DeploymentContext, deployment_name: str) -> str:
    seed = f"{context.deployment_resource_group}-{deployment_name}".lower()
    sanitized = "".join(ch for ch in seed if ch.isalnum())
    digest = hashlib.sha1(seed.encode("utf-8")).hexdigest()[:6]
    prefix = sanitized[:18]
    name = f"{prefix}{digest}"
    return (name or f"aci{digest}")[:24]


def build_azure_file_plan(
    args: argparse.Namespace,
    context: DeploymentContext,
) -> AzureFilePlan | None:
    raw_mount_specs = [parse_azure_file_mount_spec(spec) for spec in args.azure_file_mount]
    if len(raw_mount_specs) == 0:
        return None

    if len(raw_mount_specs) == 1:
        mounts_by_node = [raw_mount_specs[0] for _ in range(args.num_containers)]
    else:
        mounts_by_node = raw_mount_specs

    if any(
        mount.storage_account_name is None for mount in mounts_by_node
    ) and any(mount.storage_account_name is not None for mount in mounts_by_node):
        raise ValueError(
            "cannot mix managed and existing storage accounts across --azure-file-mount values"
        )

    provided_account_names = {
        mount.storage_account_name
        for mount in mounts_by_node
        if mount.storage_account_name is not None
    }
    uses_managed_storage = len(provided_account_names) == 0
    managed_storage_account_name = (
        derived_storage_account_name(context, args.name) if uses_managed_storage else None
    )
    planned_mounts = []
    for node_index, mount in enumerate(mounts_by_node):
        storage_account_name = mount.storage_account_name or managed_storage_account_name
        share_name = (
            derived_share_name(mount.share_name, node_index)
            if args.azure_file_share_prefix
            else mount.share_name
        )
        planned_mounts.append(
            PlannedAzureFileMount(
                node_index=node_index,
                storage_account_name=storage_account_name,
                share_name=share_name,
                mount_path=mount.mount_path,
                key_file=mount.key_file,
                delete_share_on_delete=uses_managed_storage,
            )
        )

    return AzureFilePlan(
        storage_mode=(
            AzureFileStorageMode.MANAGED
            if uses_managed_storage
            else AzureFileStorageMode.EXISTING
        ),
        mounts=planned_mounts,
        managed_storage_account_name=managed_storage_account_name,
    )


def arm_parameters_for_mounts(
    mount_configs: list[AzureFileMountConfig | None],
) -> dict[str, dict]:
    parameters = {}
    for mount_config in mount_configs:
        if mount_config is None:
            continue
        parameters[mount_config.storage_account_key_parameter] = {
            "type": "secureString",
            "metadata": {
                "description": f"Storage account key for Azure Files mount {mount_config.share_name}"
            },
        }
    return parameters


def arm_parameter_values_for_mounts(
    mount_configs: list[AzureFileMountConfig | None],
) -> dict[str, dict[str, str]]:
    values = {}
    for mount_config in mount_configs:
        if mount_config is None or mount_config.storage_account_key is None:
            continue
        values[mount_config.storage_account_key_parameter] = {
            "value": mount_config.storage_account_key,
        }
    return values


def write_parameters_file(tempf, parameter_values: dict) -> None:
    tempf.write(
        json.dumps(
            {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
                "contentVersion": "1.0.0.0",
                "parameters": parameter_values,
            },
            indent=4,
        ).encode("utf-8")
    )
    tempf.flush()


def default_container_name():
