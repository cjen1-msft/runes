def print_post_deploy_access(
    resource_group: str,
    deployment_name: str,
    num_containers: int,
    access_mode: str,
    ssh_key_path: str | None,
    vnet_name: str | None,
    subnet_name: str | None,
    delete_command: list[str] | None = None,
) -> None:
    print("Deployed")
    for cidx in range(num_containers):
        container_group_name = f"{deployment_name}-{cidx + 1}"

        if access_mode == "exec":
            print(f"Connect to container {cidx + 1} using:")
            print(
                f"az container exec --resource-group {resource_group} --name {container_group_name} --exec-command /bin/bash"
            )
            print("")
            continue

        requested_ip = requested_private_ip_for_index(cidx)
        lb_name = load_balancer_name(container_group_name)
        try:
            actual_ip = get_container_group_private_ip(resource_group, container_group_name)
        except CalledProcessError:
            actual_ip = None
            print(
                f"Warning: unable to determine actual private IP for {container_group_name}. Skipping load balancer backend update."
            )

        if actual_ip == "":
            actual_ip = None
            print(
                f"Warning: {container_group_name} did not report a private IP. Skipping load balancer backend update."
            )

        backend_name = load_balancer_backend_address_name(lb_name)

        if actual_ip is not None:
            if actual_ip != requested_ip:
                print(
                    f"Warning: {container_group_name} requested private IP {requested_ip} but Azure assigned {actual_ip}. Registering actual IP in load balancer backend address."
                )

            add_load_balancer_backend_address(
                resource_group,
                lb_name,
                backend_name,
                actual_ip,
                vnet_name,
                subnet_name,
            )
        else:
            print(
                f"Warning: backend address registration skipped for {container_group_name} because no private IP was available."
            )

        print(f"Connect to container {cidx + 1} using:")
        public_ip_name = load_balancer_public_ip_name(container_group_name)
        ssh_command = f"ssh -i {ssh_key_path} root@<public-ip> -p 22"
        try:
            public_ip = get_public_ip_address(resource_group, public_ip_name)
            print(f"ssh -i {ssh_key_path} root@{public_ip} -p 22")
        except CalledProcessError:
            print(
                f"Resolve public IP resource {public_ip_name} manually, then run: {ssh_command}"
            )
        print("")

    if delete_command is not None:
        print("Cleanup command:")
        print(shlex.join(delete_command))


