class AzureFileMountConfig:
    def __init__(
        self,
        storage_account_name: str,
        share_name: str,
        mount_path: str,
        storage_account_key_parameter: str,
        storage_account_key: str | None = None,
        volume_name: str = "azurefiles",
    ):
        self.storage_account_name = storage_account_name
        self.share_name = share_name
        self.mount_path = mount_path
        self.storage_account_key = storage_account_key
        self.storage_account_key_parameter = storage_account_key_parameter
        self.volume_name = volume_name

    def template_mount(self) -> tb.AzureFileMount:
        return tb.AzureFileMount(
            storage_account_name=self.storage_account_name,
            share_name=self.share_name,
            volume_name=self.volume_name,
            mount_path=self.mount_path,
            storage_account_key_parameter=self.storage_account_key_parameter,
        )


