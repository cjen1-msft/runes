        help=(
            "Treat share=... as a prefix and derive per-node shares like prefix-1, prefix-2. "
            "When omitted, share=... is used as-is."
        ),
    )
    return parser


def validate_args(parser: argparse.ArgumentParser, args: argparse.Namespace) -> None:
    if not args.delete and not args.image:
        parser.error("--image is required unless --delete is set")

    if args.num_containers < 1:
        parser.error("--num-containers must be at least 1")

    if args.access_mode == "ssh-lb" and not args.delete and not args.ssh_key:
        parser.error("--access-mode ssh-lb requires --ssh-key")

    if (
        args.access_mode == "ssh-lb"
        and args.create_vnet is not True
        and args.vnet_subnet is None
    ):
        parser.error("--access-mode ssh-lb requires VNet mode")

    if not args.delete and args.create_nat is True and args.create_vnet is not True:
        print("Error: --create-nat requires --create-vnet")
        sys.exit(1)

    parsed_mounts = []
    for mount_index, mount_spec in enumerate(args.azure_file_mount):
        try:
            parsed_mount = parse_azure_file_mount_spec(mount_spec)
        except ValueError as exc:
            parser.error(f"--azure-file-mount #{mount_index + 1} {exc}")
        validate_parsed_azure_file_mount(parser, parsed_mount, mount_index)
        parsed_mounts.append(parsed_mount)

    if len(parsed_mounts) > 1 and len(parsed_mounts) != args.num_containers:
        parser.error(
            "multiple --azure-file-mount values must match --num-containers"
        )

    if args.azure_file_share_prefix and len(parsed_mounts) == 0:
        parser.error("--azure-file-share-prefix requires at least one --azure-file-mount")

    if any(
        mount.storage_account_name is None for mount in parsed_mounts
    ) and any(mount.storage_account_name is not None for mount in parsed_mounts):
        parser.error(
            "cannot mix --azure-file-mount values with and without account=..."
        )

    if args.delete and args.deploy_rg and args.vnet_subnet is not None:
        # Existing subnet references remain same-resource-group only.
        pass


def build_generated_resources(
    args: argparse.Namespace,
    mount_configs: list[AzureFileMountConfig | None],
) -> tuple[list, dict[str, str | None]]:
    resources = []

    if args.create_vnet is True:
        if args.vnet_subnet is not None:
            vnet_name, subnet_name = args.vnet_subnet.split("/", 1)
        else:
            vnet_name = f"{args.name}-vnet"
            subnet_name = "default"

        if args.create_nat is True:
            nat_name = f"{args.name}-nat"
            public_ip_name = f"{args.name}-ip"
            new_res = new_vnet_with_nat(
                vnet_name, subnet_name, nat_name, public_ip_name, args.region
            )
            [_, _, vnet] = new_res
            resources.extend(new_res)
        else:
            vnet = tb.ResourceVNet(
                name=vnet_name,
                region=args.region,
                address_space="10.0.0.0/16",
                subnets=[
                    tb.VNetSubnet(
                        name=subnet_name,
                        address_prefix="10.0.0.0/24",
                        delegations=[
                            {
                                "name": "aci-delegation",
                                "properties": {
                                    "serviceName": "Microsoft.ContainerInstance/containerGroups"
                                },
                            }
                        ],
                    )
                ],
            )
            resources.append(vnet)

    elif args.vnet_subnet is not None:
        vnet_name, subnet_name = args.vnet_subnet.split("/", 1)
        vnet = tb.ResourceVNet(
            name=vnet_name,
            region=args.region,
            address_space="",
            subnets=[
                tb.VNetSubnet(
                    name=subnet_name, address_prefix=""
                )
            ],
            existing=True,
            emit_dependency=args.access_mode != "ssh-lb",
        )
        if args.access_mode != "ssh-lb":
            resources.append(vnet)
    else:
        vnet_name = None
        subnet_name = None
        vnet = None

    ports = []
    for p in (args.tcb_ports or "").split(","):
        p = p.strip()
        if p:
            ports.append({"protocol": "TCP", "port": int(p)})
    for p in (args.udp_ports or "").split(","):
        p = p.strip()
        if p:
            ports.append({"protocol": "UDP", "port": int(p)})

    for cidx in range(args.num_containers):
        container_group_name = f"{args.name}-{cidx + 1}"
        private_ip_address = None
        if args.access_mode == "ssh-lb":
            private_ip_address = requested_private_ip_for_index(cidx)

        resources.append(
            tb.ResourceACIGroup(
                container_group_name,
                args.region,
                sshkey=get_ssh_key(args.ssh_key) if args.ssh_key else None,
                containers=[
                    tb.CACI(
                        name=f"{args.name}-0",
                        image=args.image,
                        cpu=args.cpus,
                        ram=args.ram,
                        ports=ports,
                    )
                ],
                sku=args.sku,
                vnet=vnet,
                private_ip_address=private_ip_address,
                azure_file_mount=(
                    mount_configs[cidx].template_mount()
                    if mount_configs[cidx] is not None
                    else None
                ),
            ),
        )

        if args.access_mode == "ssh-lb":
            load_balancer_ip = tb.ResourcePublicIP(
                name=load_balancer_public_ip_name(container_group_name),
                region=args.region,
                sku="Standard",
                allocation_method="Static",
            )
            resources.extend(
                [
                    load_balancer_ip,
                    tb.ResourceLoadBalancer(
                        name=load_balancer_name(container_group_name),
                        region=args.region,
                        public_ip=load_balancer_ip,
                        vnet_name=vnet.name,
                        subnet_name=vnet.subnets[0].name,
                        backend_private_ip=private_ip_address,
                        depends_on_vnet=not vnet.existing or vnet.emit_dependency,
                    ),
                ]
            )

    return resources, {
        "vnet_name": vnet_name,
        "subnet_name": subnet_name,
    }


DELETE_PHASE_LABELS = [
    "containerGroups",
    "natGateways",
    "natPublicIps",
    "loadBalancers",
    "loadBalancerPublicIps",
    "virtualNetworks",
]


def build_delete_phase_membership(resources: list) -> dict[str, set[str]]:
    membership = {
        "natPublicIps": set(),
        "loadBalancerPublicIps": set(),
        "existingVirtualNetworks": set(),
    }

    for resource in resources:
        if isinstance(resource, tb.ResourceNAT):
            membership["natPublicIps"].add(resource.public_ip.name)
        elif isinstance(resource, tb.ResourceLoadBalancer):
            membership["loadBalancerPublicIps"].add(resource.public_ip.name)
        elif isinstance(resource, tb.ResourceVNet) and resource.existing:
            membership["existingVirtualNetworks"].add(resource.name)

    return membership


def build_delete_plan(resources: list) -> list[dict[str, list[dict[str, str]] | str]]:
    phases: dict[str, list[dict[str, str]]] = {label: [] for label in DELETE_PHASE_LABELS}
    membership = build_delete_phase_membership(resources)

    for resource in resources:
        item = resource.to_dict()
        resource_type = item["type"]
        name = item["name"]

        if resource_type == "Microsoft.ContainerInstance/containerGroups":
            phases["containerGroups"].append({"type": resource_type, "name": name})
        elif resource_type == "Microsoft.Network/natGateways":
            phases["natGateways"].append({"type": resource_type, "name": name})
        elif resource_type == "Microsoft.Network/loadBalancers":
            phases["loadBalancers"].append({"type": resource_type, "name": name})
        elif resource_type == "Microsoft.Network/publicIPAddresses":
            if name in membership["loadBalancerPublicIps"]:
                phases["loadBalancerPublicIps"].append({"type": resource_type, "name": name})
            elif name in membership["natPublicIps"]:
                phases["natPublicIps"].append({"type": resource_type, "name": name})
        elif resource_type == "Microsoft.Network/virtualNetworks":
            if name not in membership["existingVirtualNetworks"]:
                phases["virtualNetworks"].append({"type": resource_type, "name": name})

    return [{"label": label, "resources": phases[label]} for label in DELETE_PHASE_LABELS]


class ResourceAlreadyMissing(Exception):
    pass


def azure_delete_command(resource_group: str, resource_type: str, name: str) -> list[str]:
    return [
        "az",
        "resource",
        "delete",
        "--resource-group",
        resource_group,
        "--resource-type",
        resource_type,
        "--name",
        name,
    ]


def is_missing_resource_delete_error(
    stderr: str, resource_group: str, resource_type: str, name: str
) -> bool:
    stderr_lower = stderr.lower()
    if "resourcegroupnotfound" in stderr_lower or "subscriptionnotfound" in stderr_lower:
        return False

    resource_name = f"{resource_type}/{name}".lower()
    if "resourcenotfound" in stderr_lower and resource_name in stderr_lower:
        return True

    if (
        resource_name in stderr_lower
        and f"resource group '{resource_group.lower()}'" in stderr_lower
        and "was not found" in stderr_lower
    ):
        return True

    return False


def delete_azure_resource(resource_group: str, resource_type: str, name: str) -> None:
    command = azure_delete_command(resource_group, resource_type, name)
    print(shlex.join(command))
    result = run(command, check=False, capture_output=True, text=True)
    stderr = result.stderr or ""
    if result.returncode == 0:
        return
    if is_missing_resource_delete_error(stderr, resource_group, resource_type, name):
        raise ResourceAlreadyMissing(name)
    raise CalledProcessError(
        result.returncode,
        command,
        output=result.stdout,
        stderr=result.stderr,
    )


def execute_delete_plan(
    resource_group: str, phases: list[dict[str, list[dict[str, str]] | str]]
) -> list[str]:
    failures = []
    for phase in phases:
        for resource in phase["resources"]:
            try:
                delete_azure_resource(resource_group, resource["type"], resource["name"])
            except ResourceAlreadyMissing:
                print(f"Skipping missing resource: {resource['name']}")
            except CalledProcessError as exc:
                failures.append(resource["name"])
                print(f"Delete failed for {resource['name']}: {exc}")
                print(f"stdout: {exc.output}")
                print(f"stderr: {exc.stderr}")
    return failures


def azure_file_share_delete_command(resource_group: str, account_name: str, share_name: str) -> list[str]:
    return [
        "az",
        "storage",
        "share-rm",
        "delete",
        "--storage-account",
        account_name,
        "--name",
        share_name,
        "--resource-group",
        resource_group,
        "--only-show-errors",
    ]


def delete_azure_file_share(resource_group: str, account_name: str, share_name: str) -> None:
    command = azure_file_share_delete_command(resource_group, account_name, share_name)
    print(shlex.join(command))
    result = run(command, check=False, capture_output=True, text=True)
    stderr = result.stderr or ""
    if result.returncode == 0:
        return
    if "could not be found" in stderr.lower() or "does not exist" in stderr.lower():
        raise ResourceAlreadyMissing(share_name)
    raise CalledProcessError(
        result.returncode,
        command,
        output=result.stdout,
        stderr=result.stderr,
    )


def execute_share_delete_plan(
    resource_group: str,
    mounts: list[PlannedAzureFileMount],
) -> list[str]:
    failures = []
    seen: set[tuple[str, str]] = set()
    for mount in mounts:
        if not mount.delete_share_on_delete:
            continue
        share_id = (mount.storage_account_name, mount.share_name)
        if share_id in seen:
            continue
        seen.add(share_id)
        try:
            delete_azure_file_share(resource_group, mount.storage_account_name, mount.share_name)
        except ResourceAlreadyMissing:
            print(f"Skipping missing share: {mount.share_name}")
        except CalledProcessError as exc:
            failures.append(mount.share_name)
            print(f"Delete failed for share {mount.share_name}: {exc}")
            print(f"stdout: {exc.output}")
            print(f"stderr: {exc.stderr}")
    return failures


def render_delete_command(args: argparse.Namespace) -> list[str]:
    command = [
        "deploy-aci",
        "--resource-group",
        args.resource_group,
        "--name",
        args.name,
    ]

    if args.num_containers != 1:
        command.extend(["--num-containers", str(args.num_containers)])
    if args.create_vnet is not True:
        command.extend(["--create-vnet", "False"])
    elif args.create_nat is not True:
        command.extend(["--create-nat", "False"])
    if args.vnet_subnet is not None:
        command.extend(["--vnet-subnet", args.vnet_subnet])
    if args.access_mode != "exec":
        command.extend(["--access-mode", args.access_mode])
    if args.deploy_rg:
        command.append("--deploy-rg")
    if args.azure_file_share_prefix:
        command.append("--azure-file-share-prefix")
    for mount_spec in args.azure_file_mount:
        command.extend(["--azure-file-mount", mount_spec])

    command.append("--delete")
    return command


def print_resource_topology_message(
    args: argparse.Namespace, context: dict[str, str | None]
) -> None:
    if args.create_vnet is True:
        if args.create_nat is True:
            print(
