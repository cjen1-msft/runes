AZURE_FILE_STORAGE_KEY_PARAMETER = "azureFileStorageAccountKey"


class AzureFileMountConfig:
    def __init__(
        self,
        storage_account_name: str,
        share_name: str,
        mount_path: str,
        storage_account_key: str,
        volume_name: str = "azurefiles",
    ):
        self.storage_account_name = storage_account_name
        self.share_name = share_name
        self.mount_path = mount_path
        self.storage_account_key = storage_account_key
        self.volume_name = volume_name

    def template_mount(self) -> tb.AzureFileMount:
        return tb.AzureFileMount(
            storage_account_name=self.storage_account_name,
            share_name=self.share_name,
            volume_name=self.volume_name,
            mount_path=self.mount_path,
            storage_account_key_parameter=AZURE_FILE_STORAGE_KEY_PARAMETER,
        )


def get_ssh_key(ssh_key):
    with open(os.path.expanduser(ssh_key), "r") as f:
        return f.read().strip()


def get_secret_file_contents(path: str) -> str:
    with open(os.path.expanduser(path), "r") as f:
        return f.read().strip()


def build_azure_file_mount_config(args: argparse.Namespace) -> AzureFileMountConfig | None:
    azure_file_fields = [
        args.azure_file_storage_account,
        args.azure_file_share,
        args.azure_file_mount_path,
        args.azure_file_account_key_file,
    ]
    if not any(field is not None for field in azure_file_fields):
        return None

    storage_account_name = args.azure_file_storage_account.strip()
    share_name = args.azure_file_share.strip()
    mount_path = args.azure_file_mount_path.strip()
    storage_account_key = get_secret_file_contents(args.azure_file_account_key_file)
    return AzureFileMountConfig(
        storage_account_name=storage_account_name,
        share_name=share_name,
        mount_path=mount_path,
        storage_account_key=storage_account_key,
    )


def arm_parameters_for_mount(mount_config: AzureFileMountConfig | None) -> dict:
    if mount_config is None:
        return {}
    return {
        AZURE_FILE_STORAGE_KEY_PARAMETER: {
            "type": "secureString",
            "metadata": {
                "description": "Storage account key for Azure Files mount"
            }
        }
    }


def arm_parameter_values_for_mount(mount_config: AzureFileMountConfig | None) -> dict:
    if mount_config is None:
        return {}
    return {
        AZURE_FILE_STORAGE_KEY_PARAMETER: {
            "value": mount_config.storage_account_key,
        }
    }


def write_parameters_file(tempf, parameter_values: dict) -> None:
    tempf.write(
        json.dumps(
            {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
                "contentVersion": "1.0.0.0",
                "parameters": parameter_values,
            },
            indent=4,
        ).encode("utf-8")
    )
    tempf.flush()


def default_container_name():
    return f"test-{os.urandom(2).hex()}"


def new_vnet_with_nat(
    vnet_name, subnet_name, nat_name: str, pub_ip_name: str, region: str
) -> list:
    pub_ip = tb.ResourcePublicIP(
        name=pub_ip_name,
        region=region,
        sku="Standard",
        allocation_method="Static",
    )

    address_space = "10.0.0.0/16"

    nat_gateway = tb.ResourceNAT(
        name=nat_name,
        region=region,
        public_ip=pub_ip,
        address_space=address_space,
    )

    vnet = tb.ResourceVNet(
        name=vnet_name,
        region=region,
        address_space=address_space,
        subnets=[
            tb.VNetSubnet(
                name=subnet_name,
                address_prefix="10.0.0.0/24",
                nat_gateway=nat_gateway,
                delegations=[
                    {
                        "name": "aci-delegation",
                        "properties": {
                            "serviceName": "Microsoft.ContainerInstance/containerGroups"
                        },
                    }
                ],
            )
        ],
    )

    return [pub_ip, nat_gateway, vnet]


