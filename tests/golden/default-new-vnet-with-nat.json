{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {},
  "resources": [
    {
      "apiVersion": "2023-09-01",
      "location": "northeurope",
      "name": "baseline-nat-ip",
      "properties": {
        "idleTimeoutInMinutes": 4,
        "ipTags": [
          {
            "ipTagType": "FirstPartyUsage",
            "tag": "/NonProd"
          }
        ],
        "publicIPAddressVersion": "IPv4",
        "publicIPAllocationMethod": "Static"
      },
      "sku": {
        "name": "Standard"
      },
      "type": "Microsoft.Network/publicIPAddresses"
    },
    {
      "apiVersion": "2023-09-01",
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', 'baseline-nat-ip')]"
      ],
      "location": "northeurope",
      "name": "baseline-nat-nat",
      "properties": {
        "idleTimeoutInMinutes": 4,
        "publicIpAddresses": [
          {
            "id": "[resourceId('Microsoft.Network/publicIPAddresses', 'baseline-nat-ip')]"
          }
        ]
      },
      "sku": {
        "name": "Standard"
      },
      "type": "Microsoft.Network/natGateways"
    },
    {
      "apiVersion": "2023-09-01",
      "dependsOn": [
        "[resourceId('Microsoft.Network/natGateways', 'baseline-nat-nat')]"
      ],
      "location": "northeurope",
      "name": "baseline-nat-vnet",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.0.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "10.0.0.0/24",
              "defaultoutboundaccess": false,
              "delegations": [
                {
                  "name": "aci-delegation",
                  "properties": {
                    "serviceName": "Microsoft.ContainerInstance/containerGroups"
                  }
                }
              ],
              "natGateway": {
                "id": "[resourceId('Microsoft.Network/natGateways', 'baseline-nat-nat')]"
              }
            }
          }
        ]
      },
      "type": "Microsoft.Network/virtualNetworks"
    },
    {
      "apiVersion": "2022-10-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', 'baseline-nat-vnet')]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "location": "northeurope",
      "name": "baseline-nat-1",
      "properties": {
        "confidentialComputeProperties": {
          "ccePolicy": ""
        },
        "containers": [
          {
            "name": "baseline-nat-0",
            "properties": {
              "command": [
                "/bin/sh",
                "-c",
                "echo Fabric_NodeIPOrFQDN=$Fabric_NodeIPOrFQDN >> /aci_env && echo UVM_SECURITY_CONTEXT_DIR=$UVM_SECURITY_CONTEXT_DIR >> /aci_env && mkdir -p /root/.ssh/ && gpg --import /etc/pki/rpm-gpg/MICROSOFT-RPM-GPG-KEY && tdnf update -y && tdnf install -y openssh-server ca-certificates && tail -f /dev/null"
              ],
              "environmentVariables": [],
              "image": "ghcr.io/example/image:latest",
              "ports": [
                {
                  "port": 22,
                  "protocol": "TCP"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 4,
                  "memoryInGB": 16
                }
              },
              "securityContext": {
                "privileged": true
              },
              "volumeMounts": []
            }
          }
        ],
        "ipAddress": {
          "ports": [
            {
              "port": "22",
              "protocol": "TCP"
            }
          ],
          "type": "Private"
        },
        "osType": "Linux",
        "restartPolicy": "Never",
        "sku": "Confidential",
        "subnetIds": [
          {
            "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'baseline-nat-vnet', 'default')]"
          }
        ],
        "volumes": []
      },
      "type": "Microsoft.ContainerInstance/containerGroups"
    }
  ],
  "variables": {}
}
