    if plan.storage_mode == AzureFileStorageMode.MANAGED:
        print(
            f"- create storage account {plan.managed_storage_account_name} in {context.deployment_resource_group} ({context.region})"
        )
    else:
        print(
            f"- use existing storage account {plan.mounts[0].storage_account_name} in {context.deployment_resource_group} ({context.region})"
        )
    seen = set()
    for mount in plan.mounts:
        if mount.share_name in seen:
            continue
        seen.add(mount.share_name)
        print(
            f"- create Azure Files share {mount.share_name} in storage account {mount.storage_account_name}"
        )

